  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Sensor de presen\xE7a, localizado \nno in\xEDcio da esteira da m\xE1quina
    \nenvasadora, respons\xE1vel por \nindicar a entrada da primeira \ngarrafa na
    m\xE1quina, permitindo \nque os cilindros preenchedores \nsejam posicionados
    na posi\xE7\xE3o \ninicial. \xC9 utilizado para detectar \napenas a primeira
    garrafa da fila."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5302535af1044152a457ed104f1f4b91, type: 2}
