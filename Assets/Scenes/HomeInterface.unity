  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Desenvolver um programa em \nlinguagem Ladder (ou de sua prefer\xEAncia)\npara
    controlar o processo de envase \nde nove garrafas de suco de laranja, \nutilizando
    um CLP ou software de \nautoma\xE7\xE3o de livre escolha, com \ncomunica\xE7\xE3o
    via protocolo Modbus."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5302535af1044152a457ed104f1f4b91, type: 2}
